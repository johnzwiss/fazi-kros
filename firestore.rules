rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null && request.auth.token.email_verified == true;
    }

    function isOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

    function isAllowed() {
      return isOwner() || (
        signedIn() &&
        exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email))
      );
    }

    match /allowedEmails/{email} {
      allow get: if signedIn() && (isOwner() || request.auth.token.email == email);
      allow list, create, update, delete: if isOwner();
    }

    match /templates/{templateId} {
      allow read: if isAllowed();
      allow create, update, delete: if isOwner();
    }

    match /users/{userId} {
      allow read, create, update, delete: if isAllowed() && request.auth.uid == userId;

      match /{document=**} {
        allow read, create, update, delete: if isAllowed() && request.auth.uid == userId;
      }
    }

    match /sharedProfiles/{email} {
      allow read: if isAllowed();
      allow create, update: if isAllowed() && request.auth.token.email == email;
      allow delete: if isOwner() || (isAllowed() && request.auth.token.email == email);
    }

    function isHomeMember(homeId) {
      return isAllowed() &&
        request.auth.token.email in get(/databases/$(database)/documents/homes/$(homeId)).data.memberEmails;
    }

    match /homes/{homeId} {
      allow get: if isHomeMember(homeId);
      allow list: if isAllowed() && request.auth.token.email in resource.data.memberEmails;
      allow create: if isAllowed() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.memberEmails.size() == 2 &&
        request.auth.token.email in request.resource.data.memberEmails;
      allow update: if isHomeMember(homeId) &&
        request.resource.data.memberEmails == resource.data.memberEmails &&
        request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isHomeMember(homeId) && resource.data.createdBy == request.auth.uid;

      match /chores/{choreId} {
        allow read: if isHomeMember(homeId);
        allow create: if isHomeMember(homeId) &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.scheduledDate is string &&
          request.resource.data.title is string;
        allow update, delete: if isHomeMember(homeId);
      }
    }
  }
}
